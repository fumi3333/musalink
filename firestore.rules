rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if user is owner of the user profile
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: Enforce University Verification
    // 2 パターンを許可:
    //   1. 大学 Google アカウントでログイン（既存ユーザー後方互換）
    //   2. 個人 Gmail + OTP 在学確認済み (Custom Claim verified:true を verifyUniversityOTP が付与)
    function isVerifiedStudent() {
       return isAuthenticated() && (
         request.auth.token.email.matches('.*@stu\\.musashino-u\\.ac\\.jp$') ||
         request.auth.token.email.matches('.*@musashino-u\\.ac\\.jp$') ||
         request.auth.token.verified == true
       );
    }

    // Users: Profiles (Public Read, Owner Write — but locked-down fields server-only)
    // Server-managed fields cannot be modified by the client (IDOR/integrity防止)
    function userServerOnlyFields() {
      return [
        'trust_score',
        'ratings',
        'charges_enabled',
        'stripe_connect_id',
        'coin_balance',
        'locked_balance',
        'is_verified',
        'is_admin'
      ];
    }
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId)
                    && !request.resource.data.keys().hasAny(userServerOnlyFields());
      // Update: owner can modify their profile, but NOT server-only fields.
      // (Cloud Functions use Admin SDK which bypasses these rules — server is the only writer for those.)
      allow update: if isOwner(userId)
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(userServerOnlyFields());
      allow delete: if false;

      // Private Data Subcollection (Strictly Owner Only)
      match /private_data/{docId} {
          allow read, write: if isOwner(userId);
      }

      // Notifications Subcollection
      match /notifications/{notificationId} {
          allow read, write: if isOwner(userId);
      }
    }

    // Items: Public Read, Seller Write
    match /items/{itemId} {
      allow read: if true;
      allow create: if isVerifiedStudent() 
                    && request.resource.data.seller_id == request.auth.uid
                    && request.resource.data.price is int
                    && request.resource.data.price >= 300
                    && request.resource.data.price <= 100000
                    && request.resource.data.description.size() < 2000;
      allow update: if isAuthenticated() && (
                      (
                        resource.data.seller_id == request.auth.uid
                        && (!('price' in request.resource.data) || (request.resource.data.price is int && request.resource.data.price >= 300 && request.resource.data.price <= 100000))
                      )
                      || (
                        // Allow Buyer to lock item (Transaction Start) — only status field
                        isVerifiedStudent() 
                        && resource.data.status == 'listing'
                        && request.resource.data.status == 'matching'
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
                      )
                    );
      // 2026-05-16: seller can only delete items that are still listing — once a
      // transaction is in progress (matching) or completed (sold), the item must
      // be preserved as evidence / for the counterparty.
      allow delete: if isAuthenticated()
                    && resource.data.seller_id == request.auth.uid
                    && resource.data.status == 'listing';
    }

    // Transactions: Involved Parties Only
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.buyer_id == request.auth.uid || resource.data.seller_id == request.auth.uid);
      
      // Create: Buyer only. Enforce initial state and forbidden fields.
      // SECURITY (2026-05-16): Anonymous demo bypass removed. is_demo must be false or absent.
      allow create: if isVerifiedStudent()
                    && request.resource.data.buyer_id == request.auth.uid
                    && request.resource.data.status == 'request_sent'
                    && (!('is_demo' in request.resource.data) || request.resource.data.is_demo == false)
                    && !('unlocked_assets' in request.resource.data && request.resource.data.unlocked_assets.keys().size() > 0);
      
      // Update: Buyer or Seller with Strict State Machine
      // payment_pending -> completed is Cloud Functions ONLY (not allowed from client)
      allow update: if isVerifiedStudent() 
                    && (resource.data.buyer_id == request.auth.uid || resource.data.seller_id == request.auth.uid)
                    // Prevent client from writing unlocked_assets or is_demo
                    && (!('unlocked_assets' in request.resource.data) || request.resource.data.unlocked_assets == resource.data.unlocked_assets)
                    && (!('is_demo' in request.resource.data) || request.resource.data.is_demo == resource.data.is_demo)
                    && (
                      // 1. Non-status updates (meeting_place, etc.)
                      (!('status' in request.resource.data) || request.resource.data.status == resource.data.status)
                      ||
                      // 2. Strict status transitions only
                      (
                         // request_sent -> cancelled (Both) or approved (Seller only)
                         (resource.data.status == 'request_sent' && (
                            (request.resource.data.status == 'cancelled') || 
                            (request.resource.data.status == 'approved' && request.auth.uid == resource.data.seller_id)
                         ))
                         ||
                         // approved -> cancelled (Both, before payment)
                         (resource.data.status == 'approved' && request.resource.data.status == 'cancelled')
                         ||
                         // approved -> payment_pending (Buyer only, after Stripe auth)
                         (resource.data.status == 'approved' && request.resource.data.status == 'payment_pending' && request.auth.uid == resource.data.buyer_id)
                      )
                    );
    }

    // Conversations & Messages (Chat) -- REMOVED for 電気通信事業法 compliance (2026-05-16)
    // Reject all access. Existing data is preserved but cannot be read/written from clients.
    match /conversations/{conversationId} {
      allow read, write: if false;
      match /messages/{messageId} {
        allow read, write: if false;
      }
    }

    // Payout Requests
    match /payout_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || request.auth.token.admin == true);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // Reports
    match /reports/{reportId} {
        allow create: if isAuthenticated();
        allow read: if request.auth.token.admin == true;
    }

    // Stripe Accounts Lookup (Cloud Functions only — no client access)
    match /stripe_accounts/{accountId} {
        allow read, write: if false;
    }

    // OTP Verification — Cloud Functions (Admin SDK) のみが読み書きする。クライアントは一切不可。
    match /otp_verifications/{uid} {
        allow read, write: if false;
    }

    // OTP Rate Limits — 同上
    match /otp_rate_limits/{uid} {
        allow read, write: if false;
    }

    // Contact Form Submissions
    match /contacts/{contactId} {
        allow read: if request.auth.token.admin == true;
        allow create: if isAuthenticated();
        allow update, delete: if false;
    }
  }
}
